{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lorgar-blog-edge",
  "main": "src/index.mjs",
  "compatibility_date": "2026-07-23",
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    {
      "pattern": "lorgar.bigmax113.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
