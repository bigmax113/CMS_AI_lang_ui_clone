DATABASE_URL=postgresql://payload:payload@127.0.0.1:5432/payload
PAYLOAD_SECRET=replace-with-a-long-random-secret
PAYLOAD_ADMIN_EMAIL=dev@payloadcms.com
PAYLOAD_ADMIN_PASSWORD=test
PAYLOAD_DB_PUSH=true

AI_DOCS_DIR=./docs
PAYLOAD_UPLOAD_DIR=./media
MEDIA_DB_IMAGE_MAX_BYTES=3000000
GOOGLE_DRIVE_STORAGE_ENABLED=true
GOOGLE_DRIVE_FOLDER_ID=replace-with-drive-folder-id
GOOGLE_DRIVE_OAUTH_CLIENT_JSON_B64=replace-with-base64-oauth-client-json
GOOGLE_DRIVE_OAUTH_TOKEN_JSON_B64=replace-with-base64-oauth-token-json
GOOGLE_DRIVE_PUBLIC_READ=false
MEDIA_EXTERNAL_STORAGE_REQUIRED=false
XAI_API_KEY=replace-with-xai-api-key
XAI_BASE_URL=https://api.x.ai/v1
GROK_TEXT_MODEL=grok-4.3
GROK_IMAGE_MODEL=grok-imagine-image
GROK_VIDEO_MODEL=grok-imagine-video
GROK_VIDEO_POLL_ATTEMPTS=12
GROK_VIDEO_POLL_INTERVAL_MS=5000
